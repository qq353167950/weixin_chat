# ============================================================
# 配置说明：复制为 .env 后填写。= 两边不要空格，# 开头是注释
# 四组能力独立，不要混填 Key：
#   LLM_*=写作 | SEARCH_*=搜索 | IMAGE_*=生图 | WECHAT_*=草稿箱
# ============================================================


# ---------- A. 写作大模型（选题整理 + 写文章） ----------

# 【必填】API Key / 接口地址（OpenAI 兼容 /v1）/ 对话模型名
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 温度 0~1；单次请求超时秒数
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SEC=180

# 1=流式输出（防中转站 524 超时，推荐）；0=关闭
LLM_STREAM=1

# 候选选题个数与整理温度
TOPIC_CANDIDATE_N=5
TOPIC_LLM_TEMPERATURE=0.5


# ---------- B. 联网搜索（搜热点素材） ----------

# auto=自动（多 Key 全搜/单 Key 用该源/无 Key 走免费 ddg）
# multi=已配 Key 的源并发全搜 | 或指定：tavily/bocha/bing/serper/duckduckgo
SEARCH_PROVIDER=auto

# 各源启用开关：0=停用（配了 Key 也不参与），默认 1=启用
SEARCH_ENABLE_TAVILY=1
SEARCH_ENABLE_BOCHA=1
SEARCH_ENABLE_BING=1
SEARCH_ENABLE_SERPER=1
SEARCH_ENABLE_DUCKDUCKGO=1

# 账号领域关键词（影响搜什么）
SEARCH_DOMAIN=公众号 个人成长 职场 副业

# 各源 Key（用哪个填哪个；duckduckgo 免费无需 Key）
TAVILY_API_KEY=
BOCHA_API_KEY=
BING_API_KEY=
SERPER_API_KEY=

# 素材新鲜度（tavily 按天）；multi 模式总超时秒数
SEARCH_FRESH_DAYS=7
SEARCH_MULTI_TIMEOUT=45

# 每词结果数 / 检索词数上限 / 总结果上限 / 词间停顿秒
SEARCH_RESULTS_PER_QUERY=8
SEARCH_MAX_QUERIES=4
SEARCH_MAX_RESULTS=20
SEARCH_SLEEP_SEC=0.6

# 自定义检索词（| 分隔，可空）
# SEARCH_QUERIES=2026 公众号爆款|副业 10万+


# ---------- C. 生图模型（封面与配图） ----------

# openai=OpenAI 兼容生图 | dashscope=阿里通义万相 | template=本地文字封面（免 Key）
IMAGE_PROVIDER=openai

# 生图 Key / 接口根地址 / 模型名（与写作配置无关）
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=dall-e-3

# 尺寸（openai 如 1792x1024；dashscope 如 1280*720 用星号）
IMAGE_SIZE=1792x1024

# 风格：editorial/tech/warm/business/nature；1=封面叠中文标题
IMAGE_STYLE=editorial
IMAGE_OVERLAY_TITLE=1

# 1=生图失败退回文字模板封面
IMAGE_FALLBACK_TEMPLATE=1


# ---------- D. 微信公众号（草稿箱） ----------

# 【必填】后台 → 设置与开发 → 基本配置
WECHAT_APPID=
WECHAT_APPSECRET=

# 作者名（≤8字）；1=开评论
WECHAT_AUTHOR=
WECHAT_NEED_COMMENT=0

# 【备忘】出口 IP 须自己加白名单（查询 https://api.ipify.org）
WECHAT_IP_WHITELIST=


# ---------- E. 网络（防 Windows 10053） ----------

# 1=每次请求后强制断开连接（推荐）；重试次数与间隔
HTTP_FORCE_CLOSE=1
HTTP_RETRIES=3
HTTP_RETRY_SLEEP=1.5
LLM_HTTP_RETRIES=3


# ---------- F. 文章增强 ----------

# 1=写作前抓参考原文学语感；最多抓几篇
ARTICLE_FETCH_REFS=1
ARTICLE_REF_MAX=3

# 1=允许自动配图；每篇最多几张
ARTICLE_ILLUSTRATE=1
ARTICLE_MAX_IMAGES=3


# ---------- G. 界面与产出 ----------

# 本地服务端口；排版主题 default/hot/elegant/minimal
GUI_PORT=8093
DEFAULT_THEME=default

# runs/ 产出保留最近几次（0=不清理）
RUNS_KEEP=10

# 命令行模式默认文件
DEFAULT_MD=samples\demo.md
DEFAULT_COVER=samples\cover.jpg
WECHAT_AUTO_COVER=1
