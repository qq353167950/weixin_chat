# ============================================================
# 配置说明（请整份复制为 .env 再填写）
# ------------------------------------------------------------
# 三套能力已完全分开，不要混填：
#   A. 写作大模型  LLM_*      → 选题整理 + 写文章
#   B. 联网搜索    SEARCH_*   → 只负责搜网页热点
#   C. 生图模型    IMAGE_*    → 只负责封面图
#   D. 微信公众号  WECHAT_*   → 只负责草稿箱
# = 两边不要空格，不要加引号；# 开头是注释
# ============================================================


# ============================================================
# A. 写作大模型（选题整理 + 写文章）—— 只用 LLM_*
#    不会读 IMAGE_* / SEARCH_* 的密钥
# ============================================================

# 【必填】写作模型 API Key（Chat 对话）
LLM_API_KEY=

# 【必填】写作模型接口地址（OpenAI 兼容 /chat/completions）
# 官方示例：
LLM_BASE_URL=https://api.openai.com/v1
# 中转示例：
# LLM_BASE_URL=https://你的中转域名/v1

# 【必填】写作/选题用的对话模型名（不是生图模型名）
# 例：gpt-4o-mini / gpt-4o / deepseek-chat
LLM_MODEL=gpt-4o-mini

# 【可选】温度 0~1
LLM_TEMPERATURE=0.7

# 【可选】超时秒数
LLM_TIMEOUT_SEC=180

# 【可选】大模型整理候选选题个数
TOPIC_CANDIDATE_N=5
TOPIC_LLM_TEMPERATURE=0.5


# ============================================================
# B. 联网搜索（真实搜热点）—— 只用 SEARCH_* 及下方搜索 Key
#    不会读 LLM_* / IMAGE_* 的密钥
# ============================================================

# 【必选】搜索服务
# auto | tavily | bocha | bing | serper | duckduckgo
SEARCH_PROVIDER=auto

# 【可选】账号领域关键词（影响搜什么，不是写死标题）
SEARCH_DOMAIN=公众号 个人成长 职场 副业

# 【可选】自定义检索词，多条用 | 分隔
# SEARCH_QUERIES=2026 公众号爆款|副业 10万+

SEARCH_RESULTS_PER_QUERY=8
SEARCH_MAX_QUERIES=4
SEARCH_MAX_RESULTS=20
SEARCH_SLEEP_SEC=0.6

# --- 选 tavily 时填 ---
TAVILY_API_KEY=
TAVILY_DEPTH=basic

# --- 选 bocha 时填 ---
BOCHA_API_KEY=
# BOCHA_ENDPOINT=https://api.bochaai.com/v1/web-search

# --- 选 bing 时填 ---
BING_API_KEY=
# BING_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
BING_MKT=zh-CN

# --- 选 serper 时填 ---
SERPER_API_KEY=

# duckduckgo：无需 Key


# ============================================================
# C. 生图模型（封面）—— 只用 IMAGE_*
#    不会读 LLM_* / SEARCH_* 的密钥
# ============================================================

# 【必选】生图方式
# openai    = OpenAI 兼容 /images/generations（DALL·E 等）
# dashscope = 阿里云百炼通义万相
# template  = 本地文字封面（不调生图 API）
IMAGE_PROVIDER=openai

# 【openai / dashscope 时必填】生图专用 API Key（不要填写作 Key 到这里）
IMAGE_API_KEY=

# 【openai / dashscope 时必填】生图接口根地址
# openai 官方：
IMAGE_BASE_URL=https://api.openai.com/v1
# 生图中转：
# IMAGE_BASE_URL=https://你的生图中转/v1
# dashscope 国内：
# IMAGE_BASE_URL=https://dashscope.aliyuncs.com

# 【openai / dashscope 时必填】生图模型名（不是 LLM_MODEL）
# openai 例：dall-e-3
# dashscope 例：wanx2.1-t2i-turbo
IMAGE_MODEL=dall-e-3

# 【可选】生图尺寸（程序会再裁成公众号 900x383）
# openai 横图常用：1792x1024
# dashscope 横图常用：1280*720 （注意用星号）
IMAGE_SIZE=1792x1024

# 【可选】画面风格：editorial / tech / warm / business / nature
IMAGE_STYLE=editorial

# 【可选】1=本地叠中文标题；0=不叠字
IMAGE_OVERLAY_TITLE=1

# 【可选】1=生图失败则退回文字模板封面
IMAGE_FALLBACK_TEMPLATE=1


# ============================================================
# D. 微信公众号（草稿箱）—— 只用 WECHAT_*
# ============================================================

# 【必填】https://mp.weixin.qq.com → 设置与开发 → 基本配置
WECHAT_APPID=
WECHAT_APPSECRET=

# 【可选】作者名
WECHAT_AUTHOR=

# 【可选】0=关评论 1=开评论
WECHAT_NEED_COMMENT=0

# 【备忘】公网 IPv4，须自己去后台加白名单（脚本不会自动加）
# 浏览器查：https://api.ipify.org
WECHAT_IP_WHITELIST=


# ============================================================
# E. 网络连接（解决 Windows 10053 / 连接被中止）
# ============================================================

# 1=每次请求后强制 Connection: close，避免半开连接残留（推荐）
HTTP_FORCE_CLOSE=1

# 连接失败自动重试次数（含 10053 / Connection aborted）
HTTP_RETRIES=3

# 重试间隔秒数（会随次数递增）
HTTP_RETRY_SLEEP=1.5

# 写作大模型单独重试次数
LLM_HTTP_RETRIES=3


# ============================================================
# F. 其它（路径等，一般不用改）
# ============================================================

DEFAULT_MD=samples\demo.md
DEFAULT_COVER=samples\cover.jpg
# 排版主题：default=微信绿清爽 | hot=暖橙红爆文 | elegant=静谧蓝杂志 | minimal=黑白极简
# 全流程/GUI 里都可以在上传前实时预览并切换
DEFAULT_THEME=default
WECHAT_AUTO_COVER=1


# ============================================================
# G. 文章增强（降AI味 / 参考抓取 / 自动配图）
# ============================================================

# 1=写作前抓取搜索到的参考文章原文，喂给大模型学习真实表达（推荐开）
ARTICLE_FETCH_REFS=1

# 最多抓取几篇参考文章原文
ARTICLE_REF_MAX=3

# 1=文章生成后可自动规划并插入教程配图（使用 IMAGE_* 生图配置）
ARTICLE_ILLUSTRATE=1

# 每篇文章最多插入几张配图
ARTICLE_MAX_IMAGES=3


# ============================================================
# H. 图形界面（双击 GUI.bat 启动）
# ============================================================

# 本地 GUI 服务端口
GUI_PORT=8093


# ============================================================
# 快速对照（填哪几个）
# ------------------------------------------------------------
# 写文章/整理选题：LLM_API_KEY + LLM_BASE_URL + LLM_MODEL
# 搜热点：        SEARCH_PROVIDER + 对应搜索 Key（如 TAVILY_API_KEY）
# 生封面：        IMAGE_PROVIDER + IMAGE_API_KEY + IMAGE_BASE_URL + IMAGE_MODEL
# 进草稿箱：      WECHAT_APPID + WECHAT_APPSECRET + IP白名单
# ============================================================
